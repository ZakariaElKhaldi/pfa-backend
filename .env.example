# ============================================================
# Backend (Django) environment — copy to backend/.env and edit
# ============================================================
# This file is loaded by:
#   1. python-decouple when running Django locally (cd backend && python manage.py runserver)
#   2. docker-compose's `env_file: ./backend/.env` for web / worker / beat / alpaca_stream services
#
# For LOCAL dev without docker, change DB_HOST/REDIS_HOST to "localhost".

# --- Django ---
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Postgres) ---
POSTGRES_DB=crowdsignal
POSTGRES_USER=crowdsignal
POSTGRES_PASSWORD=crowdsignal
DB_HOST=db
DB_PORT=5432

# --- Redis / Celery ---
REDIS_HOST=redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Alpaca (paper trading keys from alpaca.markets) ---
ALPACA_URL=https://paper-api.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# --- OAuth — GitHub ---
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- OAuth — Google ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
