# ============================================================
# Backend (Django) — LOCAL DEV environment
# Copy to backend/.env and fill in local credentials.
# ============================================================

# Committed template. Do not put real secrets here.

# --- Django ---
SECRET_KEY=dev-secret-key-change-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Alpaca (paper trading) ---
ALPACA_URL=https://paper-api.alpaca.markets/v2
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Reddit API ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=crowdsignal-pfa/1.0 by u_your_reddit_username

# --- OAuth — GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- OAuth — Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Redis (Memurai) ---
REDIS_HOST=localhost
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Frontend URL (used for OAuth callback) ---
# Google Console must authorize: http://localhost:5174/auth/callback/google
FRONTEND_URL=http://localhost:5174

# --- CORS --- allow both Vite dev ports ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
